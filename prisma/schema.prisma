generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum AttendanceTiming {
  ON_TIME
  LATE
}

enum BuddyRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  displayName         String?
  passwordHash        String
  isPublic            Boolean        @default(false)
  acceptRequests Boolean @default(true)
  sessions            Session[]
  sentBuddyRequests   BuddyRequest[] @relation("BuddyRequestSender")
  receivedBuddyRequests BuddyRequest[] @relation("BuddyRequestReceiver")
  buddyConnectionsA   BuddyConnection[] @relation("BuddyConnectionA")
  buddyConnectionsB   BuddyConnection[] @relation("BuddyConnectionB")
  courses             Course[]
  classRoutines       ClassRoutine[]
  tasks               Task[]
  expenses            Expense[]
  weightLogs          WeightLog[]
  dietLogs            DietLog[]
  personalFiles       PersonalFile[]
  attendances         Attendance[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model ClassRoutine {
  id         String   @id @default(cuid())
  userId     String
  courseId   String?  // optional FK — links to Course when names match
  dayOfWeek  Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  courseName String
  room       String?
  startTime  String   // "HH:MM" 24h
  endTime    String   // "HH:MM" 24h
  color      String   @default("indigo")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, dayOfWeek])
  @@index([courseId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BuddyRequest {
  id         String             @id @default(cuid())
  pairKey    String             @unique
  senderId   String
  receiverId String
  status     BuddyRequestStatus @default(PENDING)
  respondedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  sender     User               @relation("BuddyRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User               @relation("BuddyRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([createdAt])
}

model BuddyConnection {
  id        String   @id @default(cuid())
  pairKey   String   @unique
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("BuddyConnectionA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("BuddyConnectionB", fields: [userBId], references: [id], onDelete: Cascade)

  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
}

model Course {
  id           String       @id @default(cuid())
  title        String
  creditHours  Float
  teacherName  String
  teacherInfo  String?      @db.Text
  teacherEmail String?
  teacherPhone String?
  blcLink      String?
  groupLink    String?
  ownerId      String
  deletedAt    DateTime?    // soft delete — null means active
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files        CourseFile[]
  links        CourseLink[]
  quizzes      Quiz[]
  assignments  Assignment[]
  midExam      MidExam?
  finalExam    FinalExam?
  presentation Presentation?
  attendances  Attendance[]
  routines     ClassRoutine[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ownerId, createdAt])
  @@index([ownerId, deletedAt])
}

model CourseLink {
  id        String   @id @default(cuid())
  courseId  String
  label     String
  url       String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([courseId, createdAt])
}

model CourseFile {
  id        String   @id @default(cuid())
  courseId  String
  key       String   // R2 object key (full path)
  name      String   // display name
  path      String   // parent folder path, e.g. "/" or "/Lectures/"
  isFolder  Boolean  @default(false)
  size      Int      @default(0) // bytes (0 for folders)
  mimeType  String?
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, key], name: "courseId_key")
  @@index([courseId, path])
}

model Quiz {
  id        String    @id @default(cuid())
  courseId  String
  serial    Int       @default(0)
  title     String
  syllabus  String    @db.Text
  quizDate  DateTime
  deadline  DateTime?
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([courseId, serial])
}

model Assignment {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String   @db.Text
  deadline    DateTime
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId, deadline])
}

model MidExam {
  id        String   @id @default(cuid())
  courseId  String   @unique
  syllabus  String   @db.Text
  examDate  DateTime
  venue     String?
  notes     String?  @db.Text
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinalExam {
  id        String   @id @default(cuid())
  courseId  String   @unique
  syllabus  String   @db.Text
  examDate  DateTime
  venue     String?
  notes     String?  @db.Text
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String     @id @default(cuid())
  userId    String
  title     String
  notes     String?    @db.Text
  deadline  DateTime?
  status    TaskStatus @default(TODO)
  assignees String[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, status])
  @@index([userId, deadline])
}

model Presentation {
  id               String   @id @default(cuid())
  courseId         String   @unique
  title            String
  description      String   @db.Text
  presentationDate DateTime
  venue            String?
  notes            String?  @db.Text
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Expense Tracker ───────────────────────────────────────────────────────────

enum ExpenseCategory {
  FOOD
  TRANSPORT
  HOUSING
  EDUCATION
  HEALTH
  ENTERTAINMENT
  SHOPPING
  UTILITIES
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Expense {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType @default(EXPENSE)
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory @default(OTHER)
  description String
  date        DateTime
  notes       String?         @db.Text
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, type])
}

// ── Health Tracker ────────────────────────────────────────────────────────────

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  weightKg  Decimal  @db.Decimal(5, 2)
  date      DateTime
  notes     String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum FoodHabit {
  VERY_HEALTHY
  HEALTHY
  NEUTRAL
  UNHEALTHY
  VERY_UNHEALTHY
}

model DietLog {
  id          String    @id @default(cuid())
  userId      String
  date        DateTime
  mealType    MealType
  description String
  calories    Int?
  habit       FoodHabit @default(NEUTRAL)
  notes       String?   @db.Text
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
  @@index([userId, mealType])
}

// ── Personal Storage ──────────────────────────────────────────────────────────

model PersonalFile {
  id          String   @id @default(cuid())
  userId      String
  key         String   // R2 object key  e.g. "personal/{userId}/{id}/{name}"
  name        String   // display name
  size        Int      // bytes
  mimeType    String?
  shareToken  String   @unique @default(cuid()) // public share token
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Attendance Tracker ────────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  date      String           // YYYY-MM-DD (local date, no timezone shift)
  status    AttendanceStatus @default(PRESENT)
  timing    AttendanceTiming @default(ON_TIME)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, courseId, date])
  @@index([userId, courseId])
}