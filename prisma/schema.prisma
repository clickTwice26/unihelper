generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BuddyRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  displayName         String?
  passwordHash        String
  isPublic            Boolean        @default(false)
  acceptRequests Boolean @default(true)
  sessions            Session[]
  sentBuddyRequests   BuddyRequest[] @relation("BuddyRequestSender")
  receivedBuddyRequests BuddyRequest[] @relation("BuddyRequestReceiver")
  buddyConnectionsA   BuddyConnection[] @relation("BuddyConnectionA")
  buddyConnectionsB   BuddyConnection[] @relation("BuddyConnectionB")
  courses             Course[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BuddyRequest {
  id         String             @id @default(cuid())
  pairKey    String             @unique
  senderId   String
  receiverId String
  status     BuddyRequestStatus @default(PENDING)
  respondedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  sender     User               @relation("BuddyRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User               @relation("BuddyRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, status])
  @@index([receiverId, status])
  @@index([createdAt])
}

model BuddyConnection {
  id        String   @id @default(cuid())
  pairKey   String   @unique
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("BuddyConnectionA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("BuddyConnectionB", fields: [userBId], references: [id], onDelete: Cascade)

  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
}

model Course {
  id           String       @id @default(cuid())
  title        String
  creditHours  Float
  teacherName  String
  teacherInfo  String?      @db.Text
  teacherEmail String?
  teacherPhone String?
  blcLink      String?
  groupLink    String?
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files        CourseFile[]
  links        CourseLink[]
  quizzes      Quiz[]
  assignments  Assignment[]
  midExam      MidExam?
  finalExam    FinalExam?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ownerId, createdAt])
}

model CourseLink {
  id        String   @id @default(cuid())
  courseId  String
  label     String
  url       String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([courseId, createdAt])
}

model CourseFile {
  id        String   @id @default(cuid())
  courseId  String
  key       String   // R2 object key (full path)
  name      String   // display name
  path      String   // parent folder path, e.g. "/" or "/Lectures/"
  isFolder  Boolean  @default(false)
  size      Int      @default(0) // bytes (0 for folders)
  mimeType  String?
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, key], name: "courseId_key")
  @@index([courseId, path])
}

model Quiz {
  id        String    @id @default(cuid())
  courseId  String
  serial    Int       @default(0)
  title     String
  syllabus  String    @db.Text
  quizDate  DateTime
  deadline  DateTime?
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([courseId, serial])
}

model Assignment {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String   @db.Text
  deadline    DateTime
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId, deadline])
}

model MidExam {
  id        String   @id @default(cuid())
  courseId  String   @unique
  syllabus  String   @db.Text
  examDate  DateTime
  venue     String?
  notes     String?  @db.Text
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinalExam {
  id        String   @id @default(cuid())
  courseId  String   @unique
  syllabus  String   @db.Text
  examDate  DateTime
  venue     String?
  notes     String?  @db.Text
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}